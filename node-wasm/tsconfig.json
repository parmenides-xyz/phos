{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "es6",
    "lib": ["ES2015", "DOM", "ESNext.Disposable"],
    "allowJs": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true
  },
  "files": ["./lib.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
